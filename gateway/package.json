{
  "name": "edars-gateway",
  "version": "3.0.0",
  "description": "EDARS API Gateway — Authentication, Authorization, Rate Limiting, Circuit Breaking, Threat Intel, HMAC Signing",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit",
    "test:unit": "jest tests/middleware.test.js --forceExit",
    "test:integration": "jest tests/integration.test.js --forceExit --testTimeout=30000",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint src/ --ext .js --max-warnings=0",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.0",
    "rate-limit-redis": "^4.2.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0"
  }
}