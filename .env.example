# ════════════════════════════════════════════════════════════════
# EDARS — Environment Variable Template
# ════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Replace EVERY value that says CHANGE_THIS
#   3. Generate secrets with:
#      node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   4. NEVER commit .env to git — it is already in .gitignore
# ════════════════════════════════════════════════════════════════

# ────────────────────────────────────────
# NODE ENVIRONMENT
# ────────────────────────────────────────
NODE_ENV=development
# Options: development | production | test

# ────────────────────────────────────────
# API GATEWAY
# ────────────────────────────────────────
GATEWAY_PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Production: set to your actual domain — e.g. https://app.edars.io
# Never use * in production

# ────────────────────────────────────────
# JWT AUTHENTICATION
# ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_generate_with_command_above
JWT_SECRET_LEGACY=
# JWT_SECRET_LEGACY is EMPTY by default.
# When rotating secrets:
#   1. Copy current JWT_SECRET value here
#   2. Generate a new JWT_SECRET
#   3. Restart gateway — old tokens still work for up to 8h
#   4. After 8h, clear JWT_SECRET_LEGACY

JWT_EXPIRY=8h

# ────────────────────────────────────────
# DATABASE — PostgreSQL 16
# ────────────────────────────────────────
# App connection — uses non-superuser role so RLS is enforced
DATABASE_URL=postgresql://edars_app:CHANGE_THIS@db:5432/edars

# Admin connection — only used for migrations (superuser bypasses RLS)
DATABASE_ADMIN_URL=postgresql://postgres:CHANGE_THIS@db:5432/edars

POSTGRES_DB=edars
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS

# The non-superuser app role password
DB_APP_PASSWORD=CHANGE_THIS
# This must match what is set in 007_tenant_rls.sql migration

# ────────────────────────────────────────
# REDIS 7
# ────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_THIS
# Set a password — Redis exposed without auth is a security hole

# ────────────────────────────────────────
# ANALYTICS ENGINE — Python/FastAPI
# ────────────────────────────────────────
ANALYTICS_URL=http://analytics:8000
# Internal Docker network URL — never expose this port externally

# Service-to-service auth token (gateway → analytics)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_TOKEN=CHANGE_THIS_generate_with_command_above
ANALYTICS_PORT=8000

# ────────────────────────────────────────
# MULTI-TENANCY
# ────────────────────────────────────────
# Set this to the slug of your dev tenant for local testing
DEV_TENANT_SLUG=edars-dev

# ────────────────────────────────────────
# LEGAL & COMPLIANCE
# ────────────────────────────────────────
# Version strings for Terms of Service and Privacy Policy.
# Update these when you publish a new version of either document.
# Format: YYYY-MM
CURRENT_TOS_VERSION=2026-03
CURRENT_PRIVACY_VERSION=2026-03

# URL shown in plan upgrade error responses
PRICING_URL=https://edars.io/pricing

# ────────────────────────────────────────
# RATE LIMITING
# ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
# 900000ms = 15 minutes
RATE_LIMIT_MAX=100
# Max requests per window per IP (general routes)

AUTH_RATE_LIMIT_MAX=5
# Max login attempts per IP per window before lockout
AUTH_LOCKOUT_DURATION_SECONDS=900
# 900s = 15 minutes

# ────────────────────────────────────────
# IP WHITELIST (Admin routes)
# ────────────────────────────────────────
# Comma-separated list of IPs allowed to hit /admin/* routes
ADMIN_IP_WHITELIST=127.0.0.1,::1
# Production: replace with your actual office/VPN IPs
# Example: ADMIN_IP_WHITELIST=203.0.113.5,198.51.100.10

# ────────────────────────────────────────
# ERROR TRACKING — Sentry (free tier)
# Free: sentry.io — 5,000 errors/month free
# ────────────────────────────────────────
SENTRY_DSN=
# Leave empty to disable. Set to your Sentry DSN to enable.
# Get one free at: https://sentry.io

SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# 0.1 = trace 10% of requests (sufficient for free tier)

# ────────────────────────────────────────
# MONITORING — Prometheus/Grafana (free self-hosted)
# ────────────────────────────────────────
METRICS_PORT=9090
# Port where /metrics endpoint is exposed for Prometheus scraping

# ────────────────────────────────────────
# EMAIL — Resend (free: 3,000 emails/month)
# Get free API key at: https://resend.com
# ────────────────────────────────────────
RESEND_API_KEY=
# Leave empty to disable email. Required for password reset flow.
EMAIL_FROM=noreply@edars.io

# ────────────────────────────────────────
# NGINX / TLS
# ────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
# TLS cert paths (relative to proxy/certs/)
# For production use Let's Encrypt (free): https://letsencrypt.org/

# ────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────
LOG_LEVEL=info
# Options: debug | info | warn | error
# Use 'debug' in development, 'info' or 'warn' in production
